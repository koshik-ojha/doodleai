NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
WIDGET_SECRET=your_widget_secret_key   # must match backend WIDGET_SECRET

# Optional: Embed token for loading widget on your own app
# Get this from Dashboard > Integration > Embed Code for your chatbot
NEXT_PUBLIC_WIDGET_TOKEN=your_embed_token_here
