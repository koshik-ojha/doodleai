PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/ai-chatbot
FRONTEND_URL=http://localhost:3000
OPENROUTER_API_KEY=your_openrouter_api_key   # no longer used
GOOGLE_AI_API_KEY=your_google_ai_api_key
JWT_SECRET=supersecretkey
WIDGET_SECRET=your_widget_secret_key   # used to encrypt embed tokens

# Telegram — for lead notifications (get token from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# SMTP — for OTP verification emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Doodle AI <your@gmail.com>
